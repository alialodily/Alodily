# ─── Patient Link AI · Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to git.

# ─── REQUIRED: Anthropic API Key ─────────────────────────────────────────
# Get yours from: https://console.anthropic.com/
# Used by: api/claude.js (Vercel serverless function) for all AI features
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── OPTIONAL: Custom configurations ─────────────────────────────────────
# These have sensible defaults; only set if you need to override.

# Claude model to use (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Maximum tokens per AI response (default: 2000)
# CLAUDE_MAX_TOKENS=2000

# ─── DEPLOYMENT: Vercel ──────────────────────────────────────────────────
# When deploying to Vercel, add ANTHROPIC_API_KEY via:
# 1. Vercel Dashboard → Project → Settings → Environment Variables
# OR
# 2. CLI: vercel env add ANTHROPIC_API_KEY production
